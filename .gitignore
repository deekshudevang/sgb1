# Master .gitignore for SGB Workflow Platform

# Node dependencies
**/node_modules/

# Environment variables (CRITICAL)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Build outputs
**/dist/
**/.next/
**/out/
**/build/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Temporary files
/tmp/
